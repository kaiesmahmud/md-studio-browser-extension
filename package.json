{
  "name": "md-studio-browser-extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chrome": "cross-env BROWSER_TARGET=chrome vite",
    "dev:firefox": "cross-env BROWSER_TARGET=firefox vite",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "cross-env BROWSER_TARGET=chrome tsc -b && cross-env BROWSER_TARGET=chrome vite build",
    "build:firefox": "cross-env BROWSER_TARGET=firefox tsc -b && cross-env BROWSER_TARGET=firefox vite build",
    "clean": "rimraf dist release",
    "lint": "oxlint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json}\"",
    "package:chrome": "npm run build:chrome && cd dist/chrome && zip -r ../../release/md-studio-chrome.zip . -x '*.map'",
    "package:firefox": "npm run build:firefox && web-ext build --source-dir=dist/firefox --artifacts-dir=release --overwrite-dest",
    "package": "rimraf release && mkdir -p release && npm run package:chrome && npm run package:firefox",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@fontsource-variable/geist": "^5.3.0",
    "@lezer/highlight": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "js-yaml": "^4.3.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.26.0",
    "mermaid": "^11.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "shadcn": "^4.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/chrome": "^0.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.4",
    "cross-env": "^10.1.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "web-ext": "^10.5.0",
    "webextension-polyfill": "^0.12.0"
  }
}
